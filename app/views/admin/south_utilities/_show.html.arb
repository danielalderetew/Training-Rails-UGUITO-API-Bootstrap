panel 'Utility' do
  attributes_table_for south_utility do
    utility = locals[:south]
    row :name do
      utility.name
    end
    row :code do
      utility.code
    end
    row :base_url do
      utility.base_url
    end
    row :external_api_key do
      utility.external_api_key
    end
    row :external_api_secret do
      utility.external_api_secret
    end
    row :external_api_authentication_url do
      utility.external_api_authentication_url
    end
    row :books_data_url do
      utility.books_data_url
    end
    row :notes_data_url do
      utility.notes_data_url
    end
    row :max_review_words do
      utility.max_review_words
    end
    row :medium_content_limit do
      utility.medium_content_limit
    end
    row :short_content_limit do
      utility.short_content_limit
    end
  end
end
